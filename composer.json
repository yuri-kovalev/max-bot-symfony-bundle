{
    "name": "yuri-kovalev/max-bot-symfony-bundle",
    "description": "Symfony bundle Bot API for Max Messenger",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Yuri Kovalev",
            "email": "im@yuri-kovalev.ru"
        }
    ],
    "autoload": {
        "psr-4": {
            "MaxMessenger\\Bot\\Bundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaxMessenger\\Bot\\Bundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "max-messenger-bot/max-bot-api-php": "^0.3.0",
        "symfony/config": "^6.0 || ^7.0",
        "symfony/dependency-injection": "^6.0 || ^7.0",
        "symfony/framework-bundle": "^6.0 || ^7.0",
        "symfony/http-foundation": "^6.0 || ^7.0",
        "symfony/http-kernel": "^6.0 || ^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1-dev"
        },
        "symfony": {
            "bundle": {
                "MaxMessenger\\Bot\\Bundle\\MaxBotBundle": "all"
            }
        }
    }
}
